# Copy to .env locally. On Render set these in the dashboard Environment tab.
# Never commit .env.

ANTHROPIC_API_KEY=
APP_PIN=changeme
FLASK_SECRET_KEY=replace-with-a-long-random-string
SESSION_COOKIE_SECURE=        # set true on Render (HTTPS only)
BLUEPRINT_STUB=               # set 1 for free local testing without API calls
